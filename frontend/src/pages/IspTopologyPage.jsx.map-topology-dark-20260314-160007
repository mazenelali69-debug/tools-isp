export default function IspTopologyPage() {
  const [selectedId, setSelectedId] = useState("254");
  const [traffic, setTraffic] = useState({});
  const [zoom, setZoom] = useState(0.9);
  const [offset, setOffset] = useState({ x: -120, y: 10 });
  const dragRef = useRef({ active:false, x:0, y:0, ox:0, oy:0 });

  const byId = useMemo(() => Object.fromEntries(nodes.map(n => [n.id, n])), []);
  const selected = byId[selectedId] || nodes[0];

  useEffect(() => {
    let stop = false;

    const tick = async () => {
      try {
        const res = await fetch("/api/topology/snapshot");
        const json = await res.json();
        if (!stop && json?.ok && Array.isArray(json.data)) {
          const map = Object.fromEntries(json.data.map(item => [item.id, item]));
          setTraffic(map);
        }
      } catch {}
    };

    tick();
    const timer = setInterval(tick, 3000);
    return () => {
      stop = true;
      clearInterval(timer);
    };
  }, []);

  const onWheel = (e) => {
    e.preventDefault();
    const factor = e.deltaY > 0 ? 0.92 : 1.08;
    setZoom(v => Math.max(0.45, Math.min(1.8, v * factor)));
  };

  const onMouseDown = (e) => {
    dragRef.current = {
      active: true,
      x: e.clientX,
      y: e.clientY,
      ox: offset.x,
      oy: offset.y
    };
  };

  const onMouseMove = (e) => {
    if (!dragRef.current.active) return;
    setOffset({
      x: dragRef.current.ox + (e.clientX - dragRef.current.x),
      y: dragRef.current.oy + (e.clientY - dragRef.current.y)
    });
  };

  const onMouseUp = () => {
    dragRef.current.active = false;
  };

  const selectedTraffic = Object.values(traffic).find(x => x.targetId === selectedId) ||
    Object.values(traffic).find(x => x.sourceId === selectedId) || null;

  const selectedPrimary = primaryNodeMetrics[selectedId] || null;
  const selectedPortValue = selectedPrimary ? selectedPrimary.port : (selectedTraffic ? selectedTraffic.port : "-");
  const selectedIfIndexValue = String(selectedPrimary ? selectedPrimary.ifIndex : (selectedTraffic ? selectedTraffic.ifIndex : "-"));
  const selectedRxOidValue = selectedPrimary ? selectedPrimary.rxOid : (selectedTraffic ? selectedTraffic.rxOid : "-");
  const selectedTxOidValue = selectedPrimary ? selectedPrimary.txOid : (selectedTraffic ? selectedTraffic.txOid : "-");

  return (
    <div style={{
      minHeight:"100%",
      padding:20,
      background:"linear-gradient(180deg,#040a12 0%,#07101c 100%)",
      color:"#fff"
    }}>
      <style>{`
        .topo-flow {
          stroke-dasharray: 9 14;
          animation: topoFlow 1.3s linear infinite;
        }
        @keyframes topoFlow {
          from { stroke-dashoffset: 0; }
          to { stroke-dashoffset: -46; }
        }
      `}</style>

      <div style={{ display:"grid", gridTemplateColumns:"1fr 330px", gap:16, alignItems:"start" }}>
        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          overflow:"hidden",
          background:"#06101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
        }}>
          <div style={{
            display:"flex",
            justifyContent:"space-between",
            alignItems:"center",
            padding:"14px 16px",
            borderBottom:"1px solid rgba(255,255,255,0.05)"
          }}>
            <div style={{ fontSize:18, fontWeight:800 }}>⚡ NoComment Real Topology Engine</div>
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={() => setZoom(z => Math.min(1.8, z + 0.1))} style={btnStyle}>+</button>
              <button onClick={() => setZoom(z => Math.max(0.45, z - 0.1))} style={btnStyle}>-</button>
              <button onClick={() => { setZoom(0.9); setOffset({ x:-120, y:10 }); }} style={btnStyle}>Reset</button>
            </div>
          </div>

          <div
            onWheel={onWheel}
            onMouseDown={onMouseDown}
            onMouseMove={onMouseMove}
            onMouseUp={onMouseUp}
            onMouseLeave={onMouseUp}
            style={{ height:760, overflow:"hidden", cursor: dragRef.current.active ? "grabbing" : "grab" }}
          >
            <svg width="100%" height="100%" viewBox="0 0 1600 860" style={{ display:"block" }}>
              <defs>
                <linearGradient id="bgDark" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor="#04101b" />
                  <stop offset="100%" stopColor="#030813" />
                </linearGradient>
                <radialGradient id="seaGlow" cx="50%" cy="40%" r="90%">
                  <stop offset="0%" stopColor="rgba(44,128,255,0.08)" />
                  <stop offset="100%" stopColor="rgba(44,128,255,0.00)" />
                </radialGradient>
                <linearGradient id="landFill" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stopColor="#0d1926" />
                  <stop offset="100%" stopColor="#142334" />
                </linearGradient>
              </defs>

              <LebanonMap />

              <g transform={`translate(${offset.x},${offset.y}) scale(${zoom})`}>
                {links.map((link) => {
                  const a = byId[link.source];
                  const b = byId[link.target];
                  const t = traffic[link.id];
                  const tone = loadTone(t?.totalMbps || 0);
                  const isSelected = selectedId === a.id || selectedId === b.id;

                  return (
                    <g key={link.id}>
                      <line
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={isSelected ? tone.glow : "rgba(70,160,255,0.10)"}
                        strokeWidth={isSelected ? 12 : 8}
                        strokeLinecap="round"
                      />
                      <line
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={tone.main}
                        strokeWidth={isSelected ? 3.8 : 2.4}
                        strokeLinecap="round"
                      />
                      <line
                        className="topo-flow"
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={tone.flow}
                        strokeWidth={isSelected ? 2.0 : 1.3}
                        strokeLinecap="round"
                      />
                      {t ? (
                        <g>
                          <rect
                            x={(a.x + b.x)/2 - 38}
                            y={(a.y + b.y)/2 - 13}
                            rx="8"
                            width="76"
                            height="26"
                            fill={tone.badge}
                            stroke="rgba(255,255,255,0.10)"
                          />
                          <text
                            x={(a.x + b.x)/2}
                            y={(a.y + b.y)/2 + 4}
                            textAnchor="middle"
                            fill={tone.text}
                            fontSize="10.5"
                            fontWeight="800"
                          >
                            {t.totalMbps.toFixed(1)} Mb
                          </text>
                        </g>
                      ) : null}
                    </g>
                  );
                })}

                {nodes.map((node) => {
                  const theme = nodeTheme(node.type);
                  const isSelected = selectedId === node.id;
                  return (
                    <g key={node.id} onClick={() => setSelectedId(node.id)} style={{ cursor:"pointer" }}>
                      <circle
                        cx={node.x}
                        cy={node.y}
                        r={isSelected ? 26 : 22}
                        fill={theme.glow}
                      />
                      <circle
                        cx={node.x}
                        cy={node.y}
                        r={18}
                        fill={theme.fill}
                        stroke={isSelected ? "#ffffff" : theme.stroke}
                        strokeWidth={isSelected ? 3 : 2}
                      />
                      <text
                        x={node.x}
                        y={node.y + 38}
                        textAnchor="middle"
                        fill="#f3f8ff"
                        fontSize="12.5"
                        fontWeight="700"
                      >
                        {node.label}
                      </text>
                      <text
                        x={node.x}
                        y={node.y + 54}
                        textAnchor="middle"
                        fill="#8db5e4"
                        fontSize="10.5"
                      >
                        {node.ip}
                      </text>
                    </g>
                  );
                })}
              </g>
            </svg>
          </div>
        </div>

        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          padding:16,
          background:"#07101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
        }}>
          <div style={{ color:"#7fa7d8", fontSize:11, letterSpacing:2, textTransform:"uppercase", marginBottom:8 }}>
            Selected Node
          </div>
          <div style={{ fontSize:28, fontWeight:800 }}>{selected.label}</div>
          <div style={{ color:"#9bbce5", marginTop:6, marginBottom:16 }}>{selected.ip}</div>

          <InfoCard title="Type" value={selected.type} />
          <InfoCard title="Linked Traffic" value={selectedTraffic ? `${selectedTraffic.totalMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="RX" value={selectedTraffic ? `${selectedTraffic.rxMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="TX" value={selectedTraffic ? `${selectedTraffic.txMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="Port" value={selectedPortValue} />
          <InfoCard title="ifIndex" value={selectedIfIndexValue} />
          <InfoCard title="RX OID" value={selectedRxOidValue} mono />
          <InfoCard title="TX OID" value={selectedTxOidValue} mono />
        </div>
      </div>
    </div>
  );
}

function InfoCard({ title, value, mono }) {
  return (
    <div style={{
      border:"1px solid rgba(255,255,255,0.06)",
      borderRadius:16,
      padding:12,
      background:"rgba(255,255,255,0.02)",
      marginBottom:10
    }}>
      <div style={{ color:"#7fa7d8", fontSize:11, marginBottom:6 }}>{title}</div>
      <div style={{
        color:"#eef6ff",
        fontSize: mono ? 11.5 : 15,
        fontWeight: mono ? 500 : 700,
        fontFamily: mono ? "Consolas, monospace" : "inherit",
        lineHeight:1.5,
        wordBreak:"break-all"
      }}>
        {value}
      </div>
    </div>
  );
}

const btnStyle = {
  padding:"8px 12px",
  borderRadius:12,
  border:"1px solid rgba(255,255,255,0.08)",
  background:"rgba(255,255,255,0.04)",
  color:"#fff",
  cursor:"pointer",
  fontWeight:700
};
