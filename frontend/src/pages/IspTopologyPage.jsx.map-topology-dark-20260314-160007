function nodeTheme(type) {
  if (type === "core") return { fill:"#0d2036", stroke:"#78dbff", glow:"rgba(120,219,255,.20)" };
  if (type === "tp") return { fill:"#12253a", stroke:"#4fc4ff", glow:"rgba(79,196,255,.18)" };
  if (type === "edge") return { fill:"#281a41", stroke:"#cb92ff", glow:"rgba(203,146,255,.18)" };
  return { fill:"#12253a", stroke:"#45f3b7", glow:"rgba(69,243,183,.18)" };
}

function loadTone(total) {
  if (total >= 700) return { glow:"rgba(255,72,72,.28)", main:"#ff5e5e", flow:"#ffd0d0", badge:"#511414", text:"#ffd7d7" };
  if (total >= 250) return { glow:"rgba(255,188,55,.24)", main:"#ffca58", flow:"#fff1b8", badge:"#453611", text:"#fff1bf" };
  return { glow:"rgba(61,211,255,.20)", main:"#4ad2ff", flow:"#d6f7ff", badge:"#112d3c", text:"#d8f5ff" };
}

function mapPoint(x, y) {
