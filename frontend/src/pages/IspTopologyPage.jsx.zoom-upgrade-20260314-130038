                  <pattern id="grid" width="18" height="18" patternUnits="userSpaceOnUse">
                    <path d="M 18 0 L 0 0 0 18" fill="none" stroke="rgba(120,160,255,0.045)" strokeWidth="0.7" />
                  </pattern>
