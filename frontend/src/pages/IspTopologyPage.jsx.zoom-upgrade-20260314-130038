  { id:"r15", ip:"88.88.88.15",  label:"Branch 15",  role:"Main Router", layer:"Edge", status:"up",      parent:"r7",  note:"Edge child / downstream" },
  { id:"r16", ip:"10.88.88.111", label:"Branch 10.111", role:"Main Router", layer:"Edge", status:"up",   parent:"r8",  note:"Private branch edge" }
];

const layerOrder = ["Transport", "Core", "Branch", "Edge"];
const layerY = {
  Transport: 90,
  Core: 240,
  Branch: 430,
  Edge: 620
};

function getStatusColor(status) {
  if (status === "up") return "#35f2a1";
  if (status === "warning") return "#f7c948";
  if (status === "down") return "#ff6b81";
  return "#7ea2d8";
}

function getNodeTheme(node) {
  if (node.layer === "Transport") {
    return { fill: "#f7c948", stroke: "#ffe08a", glow: "rgba(247,201,72,.22)", r: 14 };
  }
  if (node.layer === "Core") {
    return { fill: "#25c8ff", stroke: "#8fe9ff", glow: "rgba(37,200,255,.20)", r: 15 };
  }
  if (node.layer === "Edge") {
    return { fill: "#9b7bff", stroke: "#c7b7ff", glow: "rgba(155,123,255,.20)", r: 12 };
  }
  return { fill: "#35f2a1", stroke: "#a8ffdd", glow: "rgba(53,242,161,.16)", r: 13 };
}

const flowCss = `
  .topology-flow-line {
    stroke-dasharray: 6 16;
    animation: topologyFlow 1.15s linear infinite;
  }

  .topology-flow-line.dim {
    stroke-dasharray: 4 18;
    animation-duration: 1.7s;
    opacity: 0.8;
  }

  @keyframes topologyFlow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -70; }
  }
`;

function StatCard({ label, value, tone }) {
  return (
    <div style={{
      minWidth: 92,
      padding: "3px 8px",
      borderRadius: 12,
      background: tone,
      border: "1px solid rgba(255,255,255,0.08)",
      boxShadow: "0 10px 30px rgba(0,0,0,0.22)"
    }}>
      <div style={{ fontSize: 9, color: "#9fb5d8", marginBottom: 2, letterSpacing: 1, textTransform: "uppercase" }}>
        {label}
      </div>
      <div style={{ fontSize: 13, fontWeight: 800, color: "#fff", lineHeight: 1 }}>
        {value}
      </div>
    </div>
  );
}

function Pill({ children, bg, color }) {
  return (
    <div style={{
      padding: "9px 13px",
      borderRadius: 999,
      background: bg,
      border: "1px solid rgba(255,255,255,0.08)",
      color,
      fontWeight: 700,
      fontSize: 13
    }}>
      {children}
    </div>
  );
}

function buildLayout(sourceNodes) {
  const grouped = Object.fromEntries(layerOrder.map(layer => [layer, sourceNodes.filter(n => n.layer === layer)]));

  const positioned = [];
  const byId = {};

  const transportGap = 260;
  const coreGap = 170;
  const branchGap = 150;
  const edgeGap = 145;

  grouped.Transport.forEach((n, i) => {
    const x = 430 + (i * transportGap);
    const item = { ...n, x, y: layerY.Transport };
    positioned.push(item);
    byId[item.id] = item;
  });

  grouped.Core.forEach((n, i) => {
    const x = 260 + (i * coreGap);
    const item = { ...n, x, y: layerY.Core };
    positioned.push(item);
    byId[item.id] = item;
  });

  grouped.Branch.forEach((n, i) => {
    const x = 170 + (i * branchGap);
    const item = { ...n, x, y: layerY.Branch };
    positioned.push(item);
    byId[item.id] = item;
  });

  grouped.Edge.forEach((n, i) => {
    const x = 210 + (i * edgeGap);
    const item = { ...n, x, y: layerY.Edge };
    positioned.push(item);
    byId[item.id] = item;
  });

  const links = positioned
    .filter(n => n.parent)
    .map(n => [n.parent, n.id]);

  return { positioned, byId, links };
}

export default function IspTopologyPage() {
  const [query, setQuery] = useState("");
  const [selectedId, setSelectedId] = useState("c2");

  const { positioned, byId, links } = useMemo(() => buildLayout(nodes), []);

  const filteredIds = useMemo(() => {
    const q = query.trim().toLowerCase();
    if (!q) return new Set(positioned.map(n => n.id));
    return new Set(
      positioned
        .filter(n =>
          n.ip.toLowerCase().includes(q) ||
          n.label.toLowerCase().includes(q) ||
          n.role.toLowerCase().includes(q) ||
          n.layer.toLowerCase().includes(q) ||
          n.status.toLowerCase().includes(q)
        )
        .map(n => n.id)
    );
  }, [query, positioned]);

  const visibleNodes = positioned.filter(n => filteredIds.has(n.id));
  const visibleNodeIds = new Set(visibleNodes.map(n => n.id));
  const visibleLinks = links.filter(([a, b]) => visibleNodeIds.has(a) && visibleNodeIds.has(b));
  const selected = byId[selectedId] || visibleNodes[0] || positioned[0];

  const totals = useMemo(() => {
    return {
      total: positioned.length,
      transport: positioned.filter(n => n.layer === "Transport").length,
      core: positioned.filter(n => n.layer === "Core").length,
      branch: positioned.filter(n => n.layer === "Branch").length
    };
