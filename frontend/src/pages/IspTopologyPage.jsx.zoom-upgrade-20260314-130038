              placeholder="Search IP / label / role / status"
              style={{
                width: 280,
                maxWidth: "100%",
                padding: "12px 14px",
                borderRadius: 12,
                border: "1px solid rgba(255,255,255,0.10)",
                background: "rgba(255,255,255,0.04)",
                color: "#fff",
                outline: "none"
