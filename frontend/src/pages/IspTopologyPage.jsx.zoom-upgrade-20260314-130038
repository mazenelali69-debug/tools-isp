          </div>

          <div style={{ color: "#9fb5d8", marginTop: 6, marginBottom: 16 }}>
            {selected?.ip || "-"}
          </div>

          <div style={{ display: "grid", gap: 10 }}>
            <div style={{ border: "1px solid rgba(255,255,255,0.08)", borderRadius: 16, padding: 14, background: "rgba(255,255,255,0.02)" }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Role</div>
              <div style={{ fontSize: 16, fontWeight: 700 }}>{selected?.role || "-"}</div>
            </div>

            <div style={{ border: "1px solid rgba(255,255,255,0.08)", borderRadius: 16, padding: 14, background: "rgba(255,255,255,0.02)" }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Layer</div>
              <div style={{ fontSize: 16, fontWeight: 700 }}>{selected?.layer || "-"}</div>
            </div>

            <div style={{ border: "1px solid rgba(255,255,255,0.08)", borderRadius: 16, padding: 14, background: "rgba(255,255,255,0.02)" }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Status</div>
              <div style={{ display: "flex", alignItems: "center", gap: 8, fontSize: 15, fontWeight: 700 }}>
                <span style={{ width: 10, height: 10, borderRadius: 999, background: getStatusColor(selected?.status) }} />
                {String(selected?.status || "-").toUpperCase()}
              </div>
            </div>

            <div style={{ border: "1px solid rgba(255,255,255,0.08)", borderRadius: 16, padding: 14, background: "rgba(255,255,255,0.02)" }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Parent Path</div>
              <div style={{ fontSize: 14, color: "#d7e6ff", lineHeight: 1.5 }}>
                {selected?.parent ? `${byId[selected.parent]?.label || selected.parent} → ${selected.label}` : "Top-level / upstream"}
              </div>
            </div>

            <div style={{ border: "1px solid rgba(255,255,255,0.08)", borderRadius: 16, padding: 14, background: "rgba(255,255,255,0.02)" }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 4 }}>Notes</div>
              <div style={{ fontSize: 14, color: "#dbe7ff", lineHeight: 1.5 }}>
