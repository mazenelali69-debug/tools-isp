                            x={(a.x + b.x)/2}
                            y={(a.y + b.y)/2 + 4}
                            textAnchor="middle"
                            fill="#dff6ff"
                            fontSize="10"
                            fontWeight="700"
                          >
                            {t.totalMbps.toFixed(1)} Mb
                          </text>
                        </g>
                      ) : null}
                    </g>
                  );
                })}

                {nodes.map((node) => {
                  const theme = nodeTheme(node.type);
                  const isSelected = selectedId === node.id;
                  return (
                    <g key={node.id} onClick={() => setSelectedId(node.id)} style={{ cursor:"pointer" }}>
                      <circle
                        cx={node.x}
                        cy={node.y}
                        r={isSelected ? 26 : 22}
                        fill={theme.glow}
                      />
                      <circle
                        cx={node.x}
                        cy={node.y}
                        r={18}
                        fill={theme.fill}
                        stroke={isSelected ? "#ffffff" : theme.stroke}
                        strokeWidth={isSelected ? 3 : 2}
                      />
                      <text
                        x={node.x}
                        y={node.y + 38}
                        textAnchor="middle"
                        fill="#f3f8ff"
                        fontSize="12.5"
                        fontWeight="700"
                      >
                        {node.label}
                      </text>
                      <text
                        x={node.x}
                        y={node.y + 54}
                        textAnchor="middle"
                        fill="#8db5e4"
                        fontSize="10.5"
                      >
                        {node.ip}
                      </text>
                    </g>
                  );
                })}
              </g>
            </svg>
          </div>
        </div>

        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          padding:16,
          background:"#07101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
        }}>
          <div style={{ color:"#7fa7d8", fontSize:11, letterSpacing:2, textTransform:"uppercase", marginBottom:8 }}>
            Selected Node
          </div>
          <div style={{ fontSize:28, fontWeight:800 }}>{selected.label}</div>
          <div style={{ color:"#9bbce5", marginTop:6, marginBottom:16 }}>{selected.ip}</div>

          <InfoCard title="Type" value={selected.type} />
          <InfoCard title="Linked Traffic" value={selectedTraffic ? `${selectedTraffic.totalMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="RX" value={selectedTraffic ? `${selectedTraffic.rxMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="TX" value={selectedTraffic ? `${selectedTraffic.txMbps.toFixed(2)} Mbps` : "-"} />
          <InfoCard title="Port" value={selectedPortValue} />
          <InfoCard title="ifIndex" value={selectedIfIndexValue} />
          <InfoCard title="RX OID" value={selectedRxOidValue} mono />
          <InfoCard title="TX OID" value={selectedTxOidValue} mono />
        </div>
      </div>
    </div>
  );
}

function InfoCard({ title, value, mono }) {
  return (
    <div style={{
      border:"1px solid rgba(255,255,255,0.06)",
      borderRadius:16,
      padding:12,
      background:"rgba(255,255,255,0.02)",
      marginBottom:10
    }}>
      <div style={{ color:"#7fa7d8", fontSize:11, marginBottom:6 }}>{title}</div>
      <div style={{
        color:"#eef6ff",
        fontSize: mono ? 11.5 : 15,
        fontWeight: mono ? 500 : 700,
        fontFamily: mono ? "Consolas, monospace" : "inherit",
        lineHeight:1.5,
        wordBreak:"break-all"
      }}>
        {value}
      </div>
    </div>
  );
}

const btnStyle = {
  padding:"8px 12px",
  borderRadius:12,
  border:"1px solid rgba(255,255,255,0.08)",
  background:"rgba(255,255,255,0.04)",
