function nodeTheme(type) {
  if (type === "core") return { fill:"#0e2138", stroke:"#67d3ff", glow:"rgba(103,211,255,.20)" };
  if (type === "tp") return { fill:"#13263a", stroke:"#4bc0ff", glow:"rgba(75,192,255,.18)" };
  if (type === "edge") return { fill:"#25193d", stroke:"#c08cff", glow:"rgba(192,140,255,.18)" };
  return { fill:"#13253a", stroke:"#43f3b2", glow:"rgba(67,243,178,.18)" };
}

function loadTone(total) {
  if (total >= 160) return { base:"rgba(255,82,82,.18)", flow:"#ff8d8d", line:"#ff5757" };
  if (total >= 80) return { base:"rgba(255,193,7,.18)", flow:"#ffd76a", line:"#f5c542" };
  return { base:"rgba(59,205,255,.16)", flow:"#7ee7ff", line:"#46cfff" };
}

export default function IspTopologyPage() {
  const [selectedId, setSelectedId] = useState("254");
  const [traffic, setTraffic] = useState({});
  const [zoom, setZoom] = useState(0.9);
  const [offset, setOffset] = useState({ x: -120, y: 10 });
  const dragRef = useRef({ active:false, x:0, y:0, ox:0, oy:0 });

  const byId = useMemo(() => Object.fromEntries(nodes.map(n => [n.id, n])), []);
  const selected = byId[selectedId] || nodes[0];

  useEffect(() => {
    let stop = false;

    const tick = async () => {
      try {
        const res = await fetch("/api/topology/snapshot");
        const json = await res.json();
        if (!stop && json?.ok && Array.isArray(json.data)) {
          const map = Object.fromEntries(json.data.map(item => [item.id, item]));
          setTraffic(map);
        }
      } catch {}
    };

    tick();
    const timer = setInterval(tick, 3000);
    return () => {
      stop = true;
      clearInterval(timer);
    };
  }, []);

  const onWheel = (e) => {
    e.preventDefault();
    const factor = e.deltaY > 0 ? 0.92 : 1.08;
    setZoom(v => Math.max(0.45, Math.min(1.8, v * factor)));
  };

  const onMouseDown = (e) => {
    dragRef.current = {
      active: true,
      x: e.clientX,
      y: e.clientY,
      ox: offset.x,
      oy: offset.y
    };
  };

  const onMouseMove = (e) => {
    if (!dragRef.current.active) return;
    setOffset({
      x: dragRef.current.ox + (e.clientX - dragRef.current.x),
      y: dragRef.current.oy + (e.clientY - dragRef.current.y)
    });
  };

  const onMouseUp = () => {
    dragRef.current.active = false;
  };

  const selectedTraffic = Object.values(traffic).find(x => x.targetId === selectedId) ||
    Object.values(traffic).find(x => x.sourceId === selectedId) || null;

  return (
    <div style={{
      minHeight:"100%",
      padding:20,
      background:"linear-gradient(180deg,#050b14 0%,#07101c 100%)",
      color:"#fff"
    }}>
      <style>{`
        .topo-flow {
          stroke-dasharray: 8 14;
          animation: topoFlow 1.6s linear infinite;
        }
        @keyframes topoFlow {
          from { stroke-dashoffset: 0; }
          to { stroke-dashoffset: -44; }
        }
      `}</style>

      <div style={{ display:"grid", gridTemplateColumns:"1fr 320px", gap:16, alignItems:"start" }}>
        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          overflow:"hidden",
          background:"radial-gradient(circle at top, rgba(60,180,255,0.08), transparent 25%), #06101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
        }}>
          <div style={{
            display:"flex",
            justifyContent:"space-between",
            alignItems:"center",
            padding:"14px 16px",
            borderBottom:"1px solid rgba(255,255,255,0.05)"
          }}>
            <div style={{ fontSize:18, fontWeight:800 }}>⚡ NoComment Real Topology Engine</div>
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={() => setZoom(z => Math.min(1.8, z + 0.1))} style={btnStyle}>+</button>
              <button onClick={() => setZoom(z => Math.max(0.45, z - 0.1))} style={btnStyle}>-</button>
              <button onClick={() => { setZoom(0.9); setOffset({ x:-120, y:10 }); }} style={btnStyle}>Reset</button>
            </div>
          </div>

          <div
            onWheel={onWheel}
            onMouseDown={onMouseDown}
            onMouseMove={onMouseMove}
            onMouseUp={onMouseUp}
            onMouseLeave={onMouseUp}
            style={{ height:760, overflow:"hidden", cursor: dragRef.current.active ? "grabbing" : "grab" }}
          >
            <svg width="100%" height="100%" viewBox="0 0 1600 860" style={{ display:"block" }}>
              <defs>
                <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
                  <path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(80,140,255,0.08)" strokeWidth="0.6" />
                </pattern>
                <pattern id="gridb" width="100" height="100" patternUnits="userSpaceOnUse">
                  <path d="M 100 0 L 0 0 0 100" fill="none" stroke="rgba(80,140,255,0.12)" strokeWidth="0.9" />
                </pattern>
              </defs>

              <rect x="-5000" y="-5000" width="10000" height="10000" fill="url(#grid)" />
              <rect x="-5000" y="-5000" width="10000" height="10000" fill="url(#gridb)" />

              <g transform={`translate(${offset.x},${offset.y}) scale(${zoom})`}>
                {links.map((link) => {
                  const a = byId[link.source];
                  const b = byId[link.target];
                  const t = traffic[link.id];
                  const tone = loadTone(t?.totalMbps || 0);
                  const isSelected = selectedId === a.id || selectedId === b.id;

                  return (
                    <g key={link.id}>
                      <line
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={isSelected ? tone.base : "rgba(70,160,255,0.10)"}
                        strokeWidth={isSelected ? 11 : 8}
                        strokeLinecap="round"
                      />
                      <line
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={tone.line}
                        strokeWidth={isSelected ? 3.2 : 2.2}
                        strokeLinecap="round"
                      />
                      <line
                        className="topo-flow"
                        x1={a.x} y1={a.y} x2={b.x} y2={b.y}
                        stroke={tone.flow}
                        strokeWidth={isSelected ? 1.8 : 1.2}
                        strokeLinecap="round"
                      />
                      {t ? (
                        <g>
                          <rect
                            x={(a.x + b.x)/2 - 34}
                            y={(a.y + b.y)/2 - 12}
