    let stop = false;

    const tick = async () => {
      try {
        const res = await fetch("/api/topology/snapshot");
        const json = await res.json();
        if (!stop && json?.ok && Array.isArray(json.data)) {
          setTraffic(Object.fromEntries(json.data.map(x => [x.id, x])));
