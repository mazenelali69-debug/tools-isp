            <div style={{ display:"flex", gap:8, flexWrap:"wrap" }}>
              <button onClick={() => setLocked(v => !v)} style={locked ? activeBtnStyle : btnStyle}>
                {locked ? "LOCKED" : "UNLOCKED"}
