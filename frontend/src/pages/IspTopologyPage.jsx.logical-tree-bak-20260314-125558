const links = [
  ["up1","c2"], ["up2","c4"],
  ["c1","c2"], ["c2","c3"], ["c3","c4"], ["c4","c5"],
  ["c1","r1"], ["c1","r2"],
  ["c2","r3"], ["c2","r4"],
  ["c3","r5"], ["c3","r6"],
  ["c4","r7"], ["c4","r8"],
  ["c1","r9"], ["c2","r10"], ["c2","r11"], ["c3","r12"],
  ["c3","r13"], ["c4","r14"], ["c5","r15"], ["c5","r16"]
];

function getStatusColor(status) {
  if (status === "up") return "#35f2a1";
  if (status === "warning") return "#f7c948";
  if (status === "down") return "#ff6b81";
  return "#7ea2d8";
}

function getNodeTheme(node) {
  if (node.layer === "Transport") {
    return { fill: "#f7c948", stroke: "#ffe08a", glow: "rgba(247,201,72,.30)", r: 18 };
  }
  if (node.layer === "Core") {
    return { fill: "#25c8ff", stroke: "#8fe9ff", glow: "rgba(37,200,255,.26)", r: 19 };
  }
  return { fill: "#35f2a1", stroke: "#a8ffdd", glow: "rgba(53,242,161,.20)", r: 16 };
}

const flowCss = `
  .topology-flow-line {
    stroke-dasharray: 10 16;
    animation: topologyFlow 1.6s linear infinite;
  }

  .topology-flow-line.dim {
    stroke-dasharray: 8 18;
    animation-duration: 2.2s;
    opacity: 0.85;
  }

  @keyframes topologyFlow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -52; }
  }
`;
function StatCard({ label, value, tone }) {
  return (
    <div style={{
      minWidth:92,
      padding:"3px 8px",
      borderRadius:12,
      background: tone,
      border: "1px solid rgba(255,255,255,0.08)",
      boxShadow: "0 10px 30px rgba(0,0,0,0.22)"
    }}>
      <div style={{ fontSize:9, color:"#9fb5d8", marginBottom:2, letterSpacing:1, textTransform:"uppercase" }}>
        {label}
      </div>
      <div style={{ fontSize:13, fontWeight:800, color:"#fff", lineHeight:1 }}>
        {value}
      </div>
    </div>
  );
}

function Pill({ children, bg, color }) {
  return (
    <div style={{
      padding: "9px 13px",
      borderRadius: 999,
      background: bg,
      border: "1px solid rgba(255,255,255,0.08)",
      color,
      fontWeight: 700,
      fontSize: 13
    }}>
      {children}
    </div>
  );
}

export default function IspTopologyPage() {
  const [query, setQuery] = useState("");
  const [selectedId, setSelectedId] = useState("c2");

  const byId = useMemo(
    () => Object.fromEntries(nodes.map(n => [n.id, n])),
    []
  );

  const filteredIds = useMemo(() => {
    const q = query.trim().toLowerCase();
    if (!q) return new Set(nodes.map(n => n.id));
    return new Set(
      nodes
        .filter(n =>
          n.ip.toLowerCase().includes(q) ||
          n.label.toLowerCase().includes(q) ||
          n.role.toLowerCase().includes(q) ||
          n.layer.toLowerCase().includes(q) ||
          n.status.toLowerCase().includes(q)
        )
        .map(n => n.id)
    );
  }, [query]);

  const visibleNodes = nodes.filter(n => filteredIds.has(n.id));
  const visibleNodeIds = new Set(visibleNodes.map(n => n.id));
  const visibleLinks = links.filter(([a, b]) => visibleNodeIds.has(a) && visibleNodeIds.has(b));

  const selected = byId[selectedId] || visibleNodes[0] || nodes[0];

  const totals = useMemo(() => {
    return {
      total: nodes.length,
      transport: nodes.filter(n => n.layer === "Transport").length,
      core: nodes.filter(n => n.layer === "Core").length,
      branch: nodes.filter(n => n.layer === "Branch").length
    };
  }, []);

  return (
    <div style={{
      minHeight: "100%",
      padding: 22,
      background:
        "radial-gradient(circle at top left, rgba(0,170,255,0.14), transparent 28%), radial-gradient(circle at top right, rgba(120,80,255,0.10), transparent 24%), linear-gradient(180deg, #07111f 0%, #040b16 100%)",
      color: "#fff"
    }}>
      <style>{flowCss}</style>
      <div style={{ marginBottom: 18 }}>
        <div style={{
          fontSize: 12,
          letterSpacing: 2,
          textTransform: "uppercase",
          color: "#7ea2d8",
          marginBottom:4
        }}>
          ISP Topology v1
        </div>
        <div style={{ fontSize: 34, fontWeight: 800, lineHeight: 1.1 }}>
          Smart Backbone Map
        </div>
        <div style={{ marginTop: 10, color: "#a8bddf", fontSize: 14 }}>
          Static operational view — Upstream → Core → Branches
        </div>
      </div>

      <div style={{
        display: "flex",
        gap: 12,
        flexWrap: "wrap",
        marginBottom: 16
      }}>
        <StatCard label="Total Nodes" value={totals.total} tone="rgba(255,255,255,0.03)" />
        <StatCard label="Upstream" value={totals.transport} tone="rgba(247,201,72,0.10)" />
        <StatCard label="Core" value={totals.core} tone="rgba(37,200,255,0.10)" />
        <StatCard label="Branches" value={totals.branch} tone="rgba(53,242,161,0.10)" />
      </div>

      <div style={{
        display: "grid",
        gridTemplateColumns: "minmax(0, 1fr) 320px",
        gap: 16,
        alignItems: "start"
      }}>
        <div style={{
          border: "1px solid rgba(120,160,255,0.18)",
          borderRadius: 24,
          overflow: "hidden",
          background: "rgba(4, 11, 22, 0.70)",
          boxShadow: "0 20px 60px rgba(0,0,0,0.35)"
        }}>
          <div style={{
            display: "flex",
            gap: 12,
            flexWrap: "wrap",
            alignItems: "center",
            justifyContent: "space-between",
            padding: 16,
            borderBottom: "1px solid rgba(255,255,255,0.06)"
          }}>
            <div style={{ display: "flex", gap: 10, flexWrap: "wrap" }}>
              <Pill bg="rgba(247,201,72,0.12)" color="#ffe08a">Upstream / Transport</Pill>
              <Pill bg="rgba(37,200,255,0.12)" color="#8fe9ff">Core Switches</Pill>
              <Pill bg="rgba(53,242,161,0.12)" color="#a8ffdd">Main Routers / Branches</Pill>
            </div>

            <input
              value={query}
              onChange={(e) => setQuery(e.target.value)}
              placeholder="Search IP / label / role / status"
              style={{
                width: 280,
                maxWidth: "100%",
                padding: "12px 14px",
                borderRadius:12,
                border: "1px solid rgba(255,255,255,0.10)",
                background: "rgba(255,255,255,0.04)",
                color: "#fff",
                outline: "none"
              }}
            />
          </div>

          <div style={{ overflow: "auto" }}>
            <div style={{ minWidth: 1120, padding: 14 }}>
              <svg width="1080" height="620" viewBox="0 0 1420 820" style={{ display: "block" }}>
                <defs>
                  <pattern id="grid" width="22" height="22" patternUnits="userSpaceOnUse">
                    <path d="M 22 0 L 0 0 0 22" fill="none" stroke="rgba(120,160,255,0.05)" strokeWidth="0.8" />
                  </pattern>
                </defs>

                <rect x="0" y="0" width="1420" height="820" fill="url(#grid)" rx="26" />

                <text x="620" y="34" fill="#f8d66d" fontSize="13" fontWeight="700">UPSTREAM / TRANSPORT</text>
                <text x="625" y="190" fill="#74dcff" fontSize="13" fontWeight="700">MAIN SWITCHES / CORE</text>
                <text x="615" y="390" fill="#64f0b1" fontSize="13" fontWeight="700">MAIN ROUTERS / BRANCHES</text>

                {visibleLinks.map((pair, i) => {
                  const a = byId[pair[0]];
                  const b = byId[pair[1]];
                  const selectedLink = selected && (selected.id === a.id || selected.id === b.id);

                  return (
                    <g key={i}>
                      <line
                        x1={a.x}
                        y1={a.y}
                        x2={b.x}
                        y2={b.y}
                        stroke={selectedLink ? "rgba(121, 222, 255, 0.35)" : "rgba(80, 155, 255, 0.12)"}
                        strokeWidth={selectedLink ? "7" : "5"}
                        strokeLinecap="round"
                      />
                      <line
                        x1={a.x}
                        y1={a.y}
                        x2={b.x}
                        y2={b.y}
                        stroke={selectedLink ? "rgba(158, 236, 255, 0.95)" : "rgba(120, 205, 255, 0.64)"}
                        strokeWidth={selectedLink ? "2.4" : "1.7"}
                        strokeLinecap="round"
                      />
                    </g>
                  );
                })}

                {visibleNodes.map((node) => {
                  const t = getNodeTheme(node);
                  const selectedNode = selected && selected.id === node.id;
                  const statusColor = getStatusColor(node.status);

                  return (
                    <g
                      key={node.id}
                      onClick={() => setSelectedId(node.id)}
                      style={{ cursor: "pointer" }}
                    >
                      <circle cx={node.x} cy={node.y} r={t.r + (selectedNode ? 11 : 7)} fill={selectedNode ? "rgba(158,236,255,.20)" : t.glow} />
