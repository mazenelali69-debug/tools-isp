                      <circle cx={node.x + t.r - 3} cy={node.y - t.r + 4} r="4.5" fill={statusColor} stroke="#08111d" strokeWidth="2" />

                      <text
                        x={node.x}
                        y={node.y + 29}
                        textAnchor="middle"
                        fill="#e2eeff"
                        fontSize="10.5"
                        fontWeight="700"
                      >
                        {node.label}
