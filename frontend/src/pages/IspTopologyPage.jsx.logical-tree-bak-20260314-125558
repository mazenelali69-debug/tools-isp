              textTransform: "uppercase",
              letterSpacing: 2,
              color: "#7ea2d8",
              marginBottom:4
            }}>
              Selected Device
            </div>
            <div style={{ fontSize: 26, fontWeight: 800 }}>
              {selected ? selected.label : "No node"}
            </div>
            <div style={{ color: "#9db5da", marginTop: 6 }}>
              {selected ? selected.ip : "-"}
            </div>
          </div>

          <div style={{ padding: 18, display: "grid", gap: 12 }}>
            <div style={{
              padding: 14,
              borderRadius: 16,
              background: "rgba(255,255,255,0.03)",
              border: "1px solid rgba(255,255,255,0.06)"
            }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Role</div>
              <div style={{ fontSize: 16, fontWeight: 700 }}>{selected?.role || "-"}</div>
            </div>

            <div style={{
              padding: 14,
              borderRadius: 16,
              background: "rgba(255,255,255,0.03)",
              border: "1px solid rgba(255,255,255,0.06)"
            }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Layer</div>
              <div style={{ fontSize: 16, fontWeight: 700 }}>{selected?.layer || "-"}</div>
            </div>

            <div style={{
              padding: 14,
              borderRadius: 16,
              background: "rgba(255,255,255,0.03)",
              border: "1px solid rgba(255,255,255,0.06)"
            }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Status</div>
              <div style={{
                display: "inline-flex",
                alignItems: "center",
                gap: 8,
                fontSize: 15,
                fontWeight: 800,
                color: getStatusColor(selected?.status || "unknown")
              }}>
                <span style={{
                  width: 10,
                  height: 10,
                  borderRadius: 999,
                  background: getStatusColor(selected?.status || "unknown"),
                  display: "inline-block"
                }} />
                {(selected?.status || "unknown").toUpperCase()}
              </div>
            </div>

            <div style={{
              padding: 14,
              borderRadius: 16,
              background: "rgba(255,255,255,0.03)",
              border: "1px solid rgba(255,255,255,0.06)"
            }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom: 6 }}>Notes</div>
              <div style={{ fontSize: 14, color: "#d7e6ff", lineHeight: 1.5 }}>
                {selected?.note || "-"}
              </div>
            </div>

            <div style={{
              padding: 14,
              borderRadius: 16,
              background: "rgba(120,160,255,0.06)",
              border: "1px solid rgba(120,160,255,0.10)"
            }}>
              <div style={{ color: "#7ea2d8", fontSize: 12, marginBottom:4 }}>Phase</div>
              <div style={{ fontSize: 14, color: "#dbe7ff", lineHeight: 1.5 }}>
                Static Smart Topology.
                Ready later for live ping, SNMP, utilization, alarms, and interface-level paths.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}







