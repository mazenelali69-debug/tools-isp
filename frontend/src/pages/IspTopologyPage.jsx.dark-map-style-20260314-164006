function toneForTraffic(total) {
  if (total >= 700) return { color:"#ff4d5e", text:"#ffd9de", badge:"rgba(58,12,18,.90)" };
  if (total >= 250) return { color:"#ffc857", text:"#fff2c9", badge:"rgba(56,42,10,.90)" };
  return { color:"#46d6ff", text:"#d9f8ff", badge:"rgba(10,34,44,.92)" };
}

function nodeStyle(type, selected) {
  if (type === "core") return { radius: selected ? 11 : 9, fillColor:"#7edcff", color:"#f4fcff", weight:2.2, fillOpacity:0.96 };
  if (type === "tp")   return { radius: selected ? 10 : 8, fillColor:"#58c8ff", color:"#f4fcff", weight:2.1, fillOpacity:0.96 };
  if (type === "edge") return { radius: selected ? 9 : 7, fillColor:"#c997ff", color:"#fbf3ff", weight:2.0, fillOpacity:0.96 };
  return { radius: selected ? 10 : 8, fillColor:"#4af0b9", color:"#f2fffb", weight:2.1, fillOpacity:0.96 };
}

function midpoint(a, b) {
  return [(a.lat + b.lat) / 2, (a.lng + b.lng) / 2];
}

function curvedPositions(a, b, bend = 0.00018) {
  const midLat = (a.lat + b.lat) / 2;
  const midLng = (a.lng + b.lng) / 2;
  const dx = b.lng - a.lng;
  const dy = b.lat - a.lat;
  const len = Math.sqrt(dx * dx + dy * dy) || 1;
  const nx = -dy / len;
  const ny = dx / len;
  return [
    [a.lat, a.lng],
    [midLat + ny * bend, midLng + nx * bend],
    [b.lat, b.lng]
  ];
}

function SvgLinkLayer({ traffic, selectedId, nodeMeta }) {
  const map = useMap();
  const size = map.getSize();
  const [, setTick] = useState(0);

  useEffect(() => {
    const rerender = () => setTick(v => v + 1);
    map.on("move zoom zoomend moveend resize", rerender);
    return () => {
      map.off("move zoom zoomend moveend resize", rerender);
    };
  }, [map]);

  const project = (lat, lng) => {
    const p = map.latLngToLayerPoint([lat, lng]);
    return { x: p.x, y: p.y };
  };

  const paths = links.map((link) => {
    const a = nodeMeta[link.source];
    const b = nodeMeta[link.target];
    const tone = toneForTraffic(traffic[link.id]?.totalMbps || 0);
    const isSelected = selectedId === link.source || selectedId === link.target;

    const pts = curvedPositions(a, b, 0.00018);
    const p1 = project(pts[0][0], pts[0][1]);
    const p2 = project(pts[1][0], pts[1][1]);
    const p3 = project(pts[2][0], pts[2][1]);

    return {
      id: link.id,
      d: `M ${p1.x} ${p1.y} Q ${p2.x} ${p2.y} ${p3.x} ${p3.y}`,
      tone,
      isSelected
    };
  });

  return (
    <svg
      style={{
        position:"absolute",
        inset:0,
        width:"100%",
        height:"100%",
        pointerEvents:"none",
        zIndex:350
      }}
      viewBox={`0 0 ${size.x} ${size.y}`}
    >
      <defs>
        <filter id="softGlow">
          <feGaussianBlur stdDeviation="3.5" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      {paths.map((p) => (
        <g key={p.id}>
          <path
            d={p.d}
            fill="none"
            stroke={p.isSelected ? "rgba(255,255,255,.12)" : "rgba(75,160,255,.08)"}
            strokeWidth={p.isSelected ? 12 : 8}
            strokeLinecap="round"
            filter="url(#softGlow)"
          />
          <path
            d={p.d}
            fill="none"
            stroke={p.tone.color}
            strokeWidth={p.isSelected ? 4 : 3}
            strokeLinecap="round"
          />
          <path
            d={p.d}
            fill="none"
            stroke="#ffffff"
            strokeOpacity={p.isSelected ? 0.9 : 0.5}
            strokeWidth={p.isSelected ? 1.3 : 0.9}
            strokeLinecap="round"
            strokeDasharray="10 12"
          >
            <animate attributeName="stroke-dashoffset" from="0" to="-44" dur="1.15s" repeatCount="indefinite" />
          </path>
        </g>
      ))}
    </svg>
  );
}

function ForceMapRefreshOnSelect({ center, locked }) {
  const map = useMap();
  useEffect(() => {
    if (locked) return;
    map.panTo(center, { animate: true, duration: 0.6 });
  }, [center, map, locked]);
  return null;
}

export default function IspTopologyPage() {
  const [traffic, setTraffic] = useState({});
  const [selectedId, setSelectedId] = useState("254");
  const [mapKey, setMapKey] = useState(1);
  const [locked, setLocked] = useState(false);
  const [nodeMeta, setNodeMeta] = useState(DEFAULT_NODE_META);

  useEffect(() => {
    let stop = false;
    const tick = async () => {
      try {
        const res = await fetch("/api/topology/snapshot");
        const json = await res.json();
        if (!stop && json?.ok && Array.isArray(json.data)) {
          setTraffic(Object.fromEntries(json.data.map(x => [x.id, x])));
        }
      } catch {}
    };
    tick();
    const timer = setInterval(tick, 3000);
    return () => {
      stop = true;
      clearInterval(timer);
    };
  }, []);

  useEffect(() => {
    let stop = false;
    const loadPositions = async () => {
      try {
        const res = await fetch("/api/topology/positions");
        const json = await res.json();
        if (!stop && json?.ok && json.data) {
          const merged = { ...DEFAULT_NODE_META };
          Object.keys(json.data).forEach((id) => {
            if (merged[id] && typeof json.data[id]?.lat === "number" && typeof json.data[id]?.lng === "number") {
              merged[id] = { ...merged[id], lat: json.data[id].lat, lng: json.data[id].lng };
            }
          });
          setNodeMeta(merged);
        }
      } catch {}
    };
    loadPositions();
    return () => { stop = true; };
  }, []);

  const updateNode = (id, lat, lng) => {
    setNodeMeta(prev => ({
      ...prev,
      [id]: { ...prev[id], lat, lng }
    }));
  };

  const saveLayout = async () => {
    const payload = Object.fromEntries(
      Object.entries(nodeMeta).map(([id, node]) => [id, { lat: node.lat, lng: node.lng }])
    );

    try {
      await fetch("/api/topology/positions", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      alert("Layout saved.");
    } catch {
      alert("Save failed.");
    }
  };

  const resetLayout = async () => {
    setNodeMeta(DEFAULT_NODE_META);
    try {
      const payload = Object.fromEntries(
        Object.entries(DEFAULT_NODE_META).map(([id, node]) => [id, { lat: node.lat, lng: node.lng }])
      );
      await fetch("/api/topology/positions", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
    } catch {}
    setMapKey(v => v + 1);
  };

  const selectedNode = nodeMeta[selectedId] || nodeMeta["254"];
  const selectedTraffic =
    Object.values(traffic).find(x => x.targetId === selectedId) ||
    Object.values(traffic).find(x => x.sourceId === selectedId) ||
    null;

  const selectedPrimary = primaryNodeMetrics[selectedId] || null;
  const selectedPortValue = selectedPrimary ? selectedPrimary.port : (selectedTraffic ? selectedTraffic.port : "-");
  const selectedIfIndexValue = String(selectedPrimary ? selectedPrimary.ifIndex : (selectedTraffic ? selectedTraffic.ifIndex : "-"));
  const selectedRxOidValue = selectedPrimary ? selectedPrimary.rxOid : (selectedTraffic ? selectedTraffic.rxOid : "-");
  const selectedTxOidValue = selectedPrimary ? selectedPrimary.txOid : (selectedTraffic ? selectedTraffic.txOid : "-");
  const selectedCenter = [selectedNode.lat, selectedNode.lng];

  return (
    <div style={{
      minHeight:"100%",
      padding:20,
      background:"linear-gradient(180deg,#040912 0%,#070f18 100%)",
      color:"#fff"
    }}>
      <style>{`
        .leaflet-container {
          background: #02060b !important;
          font-family: Segoe UI, Arial, sans-serif;
        }

        .topology-map .leaflet-pane,
        .topology-map .leaflet-top,
        .topology-map .leaflet-bottom {
          z-index: 300;
        }

        .topology-map .leaflet-tile-pane {
          filter: brightness(0.16) contrast(1.45) saturate(0) grayscale(1);
        }

        .topology-map .leaflet-overlay-pane,
        .topology-map .leaflet-tooltip-pane {
          pointer-events: none;
        }

        .topology-map .leaflet-control-container,
        .topology-map .leaflet-marker-pane {
          pointer-events: auto;
        }

        .topology-map .leaflet-control-zoom a {
          background: rgba(5,10,18,.94);
          color: #fff;
          border-bottom: 1px solid rgba(255,255,255,.08);
        }

        .traffic-badge {
          background: rgba(4,10,18,.90);
          border: 1px solid rgba(255,255,255,.08);
          color: #e8f7ff;
          border-radius: 999px;
          padding: 2px 8px;
          font-size: 10px;
          font-weight: 800;
          box-shadow: 0 8px 24px rgba(0,0,0,.35);
          white-space: nowrap;
          pointer-events: none !important;
        }

        .node-label {
          color: #f7fbff;
          font-size: 11px;
          font-weight: 800;
          text-shadow: 0 2px 8px rgba(0,0,0,.95);
          white-space: nowrap;
          pointer-events: none !important;
        }

        .node-ip {
          color: #a6c3e6;
          font-size: 10px;
          font-weight: 700;
          text-shadow: 0 2px 8px rgba(0,0,0,.95);
          white-space: nowrap;
          pointer-events: none !important;
        }
      `}</style>

      <div style={{ display:"grid", gridTemplateColumns:"1fr 330px", gap:16, alignItems:"start" }}>
        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          overflow:"hidden",
          background:"#06101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
