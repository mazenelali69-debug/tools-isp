          <div style={{
            display:"flex",
            justifyContent:"space-between",
            alignItems:"center",
            padding:"14px 16px",
            borderBottom:"1px solid rgba(255,255,255,0.05)"
          }}>
            <div style={{ fontSize:18, fontWeight:800 }}>⚡ NoComment Live Map Topology</div>
            <div style={{ display:"flex", gap:8 }}>
              <button onClick={() => setLocked(v => !v)} style={btnStyle}>{locked ? "Unlock" : "Lock"}</button>
              <button onClick={saveLayout} style={btnStyle}>Save Layout</button>
              <button onClick={resetLayout} style={btnStyle}>Reset Layout</button>
              <button onClick={() => setMapKey(v => v + 1)} style={btnStyle}>Reset Map</button>
            </div>
          </div>

          <div className="topology-map" style={{ height:820, position:"relative" }}>
            <MapContainer
              key={mapKey}
              center={OFFICE}
              zoom={15}
              minZoom={13}
              maxZoom={19}
              zoomSnap={0.25}
              scrollWheelZoom={!locked}
              dragging={!locked}
              doubleClickZoom={!locked}
              boxZoom={!locked}
              keyboard={!locked}
              zoomControl={true}
              style={{ width:"100%", height:"100%" }}
            >
              <ForceMapRefreshOnSelect center={selectedCenter} locked={locked} />
              <TileLayer
                attribution='&copy; OpenStreetMap contributors'
                url="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
              />

              <SvgLinkLayer traffic={traffic} selectedId={selectedId} nodeMeta={nodeMeta} />

              {links.map((link) => {
                const a = nodeMeta[link.source];
                const b = nodeMeta[link.target];
                const t = traffic[link.id];
                const m = midpoint(a, b);

                return t ? (
                  <CircleMarker
                    key={link.id + "-mid"}
                    center={m}
                    radius={0.1}
                    pathOptions={{ opacity:0, fillOpacity:0 }}
                  >
                    <Tooltip permanent direction="center" opacity={1} className="traffic-badge">
                      {t.totalMbps.toFixed(1)} Mb
                    </Tooltip>
                  </CircleMarker>
                ) : null;
              })}

              {Object.entries(nodeMeta).map(([id, node]) => {
                const style = nodeStyle(node.type, selectedId === id);
                return (
                  <React.Fragment key={id}>
                    <Marker
                      position={[node.lat, node.lng]}
                      draggable={!locked}
                      icon={invisibleMarkerIcon}
                      eventHandlers={{
                        dragend: (e) => {
                          const p = e.target.getLatLng();
                          updateNode(id, p.lat, p.lng);
                        },
                        click: () => setSelectedId(id)
                      }}
                    />

                    <CircleMarker
                      center={[node.lat, node.lng]}
                      radius={style.radius}
                      pathOptions={{
                        color: style.color,
                        weight: style.weight,
                        fillColor: style.fillColor,
                        fillOpacity: style.fillOpacity
                      }}
                      eventHandlers={{ click: () => setSelectedId(id) }}
                    >
                      <Tooltip direction="top" offset={[0,-8]} opacity={1}>
                        <div style={{ minWidth: 180 }}>
                          <div style={{ fontWeight: 800 }}>{node.label}</div>
                          <div>{node.ip}</div>
                        </div>
                      </Tooltip>
                    </CircleMarker>

                    <CircleMarker
                      center={[node.lat - 0.00018, node.lng]}
                      radius={0.1}
                      pathOptions={{ opacity:0, fillOpacity:0 }}
                    >
                      <Tooltip permanent direction="bottom" offset={[0,0]} opacity={1} className="node-label">
                        {node.label}
                      </Tooltip>
                    </CircleMarker>

                    <CircleMarker
                      center={[node.lat - 0.00035, node.lng]}
                      radius={0.1}
                      pathOptions={{ opacity:0, fillOpacity:0 }}
                    >
                      <Tooltip permanent direction="bottom" offset={[0,0]} opacity={1} className="node-ip">
                        {node.ip}
                      </Tooltip>
                    </CircleMarker>
                  </React.Fragment>
                );
              })}
            </MapContainer>
          </div>
        </div>

        <div style={{
          border:"1px solid rgba(120,160,255,0.14)",
          borderRadius:24,
          padding:16,
          background:"#07101a",
          boxShadow:"0 24px 80px rgba(0,0,0,0.35)"
