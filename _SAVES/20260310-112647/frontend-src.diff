diff --git a/frontend/src/index.css b/frontend/src/index.css
index 0b53605..52abb61 100644
--- a/frontend/src/index.css
+++ b/frontend/src/index.css
@@ -5942,3 +5942,143 @@ body{
    DASH-METRICS-ONE-LINE-END
    ===================================== */
 
+
+/* WELCOME-TOAST-START */
+.dashx-welcomeToast{
+  position: fixed;
+  top: 18px;
+  right: 18px;
+  z-index: 9999;
+  padding: 12px 16px;
+  border-radius: 14px;
+  background: linear-gradient(180deg, rgba(18,28,43,.98), rgba(10,18,29,.98));
+  border: 1px solid rgba(255,255,255,.10);
+  box-shadow: 0 18px 40px rgba(0,0,0,.28);
+  color: #eef6ff;
+  font-size: 14px;
+  font-weight: 900;
+  letter-spacing: .01em;
+  backdrop-filter: blur(8px);
+  animation: dashxWelcomeIn .22s ease-out;
+}
+
+@keyframes dashxWelcomeIn{
+  from{
+    opacity: 0;
+    transform: translateY(-8px);
+  }
+  to{
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+/* WELCOME-TOAST-END */
+
+
+.dashx-midFull__topbusy{
+  width:100% !important;
+  max-width:none !important;
+}
+
+.dashx-panel{
+  width:100% !important;
+}
+
+.dashx-midFull{
+  width:100% !important;
+}
+
+
+.dashx-page{
+  width:100%;
+  max-width:1600px;
+  margin:0 auto;
+  padding:20px;
+}
+
+.dashx-midFull{
+  display:grid;
+  grid-template-columns:1fr;
+  gap:14px;
+  width:100%;
+}
+
+.dashx-midFull__topbusy{
+  width:100%;
+}
+
+.fwb-list{
+  width:100%;
+}
+
+.fwb-row{
+  width:100%;
+}
+
+.fwb-row__bar{
+  width:100%;
+}
+
+
+
+
+/* ===== PING-DOWN-SPACE ===== */
+.dashx-pings,
+.service-pings,
+.pingSection{
+  margin-top:20vh;
+}
+/* ===== END ===== */
+
+
+
+
+
+/* ===== TOP BUSY BIGGER ROWS ===== */
+
+.fwb-row{
+  padding-top:10px;
+  padding-bottom:10px;
+}
+
+.fwb-row__bar{
+  margin-top:8px;
+}
+
+.fwb-strip{
+  transform:scaleY(1.35);
+  transform-origin:center;
+}
+
+/* ===== END ===== */
+
+
+
+
+
+
+/* ===== TOP BUSY HEAT BAR STYLE ===== */
+
+.pressure-row{
+  width:100%;
+}
+
+.pressure-bar{
+  display:flex;
+  gap:0px !important;
+  width:100%;
+}
+
+.pressure-seg{
+  flex:1;
+  height:12px;
+  margin:0 !important;
+  border-radius:0 !important;
+}
+
+/* smooth gradient */
+.pressure-seg.green  { background:#2ecc71 }
+.pressure-seg.yellow { background:#f1c40f }
+.pressure-seg.orange { background:#e67e22 }
+.pressure-seg.red    { background:#e74c3c }
+
