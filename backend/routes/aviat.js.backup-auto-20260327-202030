const express = require("express");
const router = express.Router();
const snmp = require("net-snmp");

// 🔥 بدنا نحدد الـ OIDs الصح من snmpwalk تبعك
// 👇 حط هون القيم يلي بتزيد (octets counters)

const OID_RX = "PUT_RX_OID_HERE";
const OID_TX = "PUT_TX_OID_HERE";

function sleep(ms) {
  return new Promise((r) => setTimeout(r, ms));
}

function getSNMP(session, oids) {
  return new Promise((resolve, reject) => {
    session.get(oids, (err, varbinds) => {
      if (err) return reject(err);
      resolve(varbinds.map(v => Number(v.value)));
    });
  });
}

router.get("/aviat/throughput", async (req, res) => {
  const ip = req.query.ip;
  const community = req.query.community || "public";
  const ms = Number(req.query.ms || 2000);

  if (!ip) {
    return res.status(400).json({ ok: false, error: "ip required" });
  }

  const session = snmp.createSession(ip, community);

  try {
    const [rx1, tx1] = await getSNMP(session, [OID_RX, OID_TX]);
    await sleep(ms);
    const [rx2, tx2] = await getSNMP(session, [OID_RX, OID_TX]);

    const deltaSec = ms / 1000;

    const rxMbps = ((rx2 - rx1) * 8) / (deltaSec * 1_000_000);
    const txMbps = ((tx2 - tx1) * 8) / (deltaSec * 1_000_000);

    session.close();

    res.json({
      ok: true,
      ip,
      rxMbps,
      txMbps
    });

  } catch (e) {
    session.close();
    res.json({ ok: false, error: e.message });
  }
});

module.exports = router;
