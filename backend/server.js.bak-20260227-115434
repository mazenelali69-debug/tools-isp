app.post("/api/debug/walk-ifdescr", async (req, res) => {
  const { ip, community } = req.body || {};
  if (!ip || !community)
    return res.status(400).json({ ok:false });

  const session = makeSession(ip, community);
  const OID = "1.3.6.1.2.1.2.2.1.2";

  const rows = [];

  try {
    await new Promise((resolve,reject)=>{
      session.subtree(OID, vb=>{
        if (!vb || !vb.oid || typeof vb.oid !== "string") return;
        if (snmp.isVarbindError(vb)) return;
        rows.push({ oid: vb.oid, value: String(vb.value) });
      }, err=>err?reject(err):resolve());
    });

    res.json({ ok:true, count: rows.length, rows });
  } catch (e) {
    res.status(500).json({ ok:false, error:String(e.message||e) });
  } finally {
    try { session.close(); } catch {}
  }
});
const OIDS = [
  "1.3.6.1.2.1.31.1.1.1.1", // ifName
  "1.3.6.1.2.1.2.2.1.2",    // ifDescr
  "1.3.6.1.2.1.31.1.1.1.18",// ifAlias
  "1.3.6.1.2.1.17.1.4.1.2"  // bridge ports
];

app.post("/api/interfaces-universal", async (req,res)=>{
  const {ip,community}=req.body||{};
  if(!ip||!community) return res.status(400).json({ok:false});

  const session=makeSession(ip,community);
  const results={};

  try{
    for(const OID of OIDS){
      await new Promise((resolve)=>{
        session.subtree(OID,vb=>{
          if(!vb||!vb.oid||typeof vb.oid!=="string") return;
          if(snmp.isVarbindError(vb)) return;
          const idx=parseInt(vb.oid.split(".").pop(),10);
          if(!Number.isFinite(idx)) return;

          if(!results[idx]) results[idx]={ifIndex:idx};
          results[idx].value=String(vb.value);
        },()=>resolve());
      });
    }

    const rows=Object.values(results);
    res.json({ok:true,count:rows.length,interfaces:rows});
  }catch(e){
    res.status(500).json({ok:false,error:String(e.message||e)});
  }finally{
    try{session.close();}catch{}
  }
});
